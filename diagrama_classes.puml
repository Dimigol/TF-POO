@startuml DiagramaClassesEstacionamento
skinparam classAttributeIconSize 0
hide circle

abstract class Cliente {
  - identificador : String
  - nome : String
  - placas : Set<String>
  - limitePlacas : int
  + adicionarPlaca(placa : String) : boolean
  + removerPlaca(placa : String) : boolean
  + podeEntrar(placa : String, estacionadas : Set<String>) : boolean
  + {abstract} getTipo() : TipoCliente
  + {abstract} calcularCusto(registro, tarifas) : double
}

class ClienteAvulso
class Professor {
  + temVeiculoEstacionado(estacionadas : Set<String>) : boolean
}
class Estudante {
  - saldo : double
  + adicionarCredito(valor : double)
  + debitar(valor : double)
  + estaBloqueado() : boolean
}
class Empresa {
  - debitoAcumulado : double
  - inadimplente : boolean
  + adicionarDebito(valor : double)
  + emitirBoleto() : double
  + marcarBoletoVencido()
  + registrarPagamento(valor : double)
}

Cliente <|-- ClienteAvulso
Cliente <|-- Professor
Cliente <|-- Estudante
Cliente <|-- Empresa

enum TipoCliente {
  PROFESSOR
  ESTUDANTE
  EMPRESA
  AVULSO
}

class Veiculo {
  - placa : String
  - proprietario : Cliente
}

class RegistroEstacionamento {
  - placa : String
  - tipoCliente : TipoCliente
  - identificadorProprietario : String
  - entrada : LocalDateTime
  - saida : LocalDateTime
  - custo : double
  - idDesconto : String
  - valorDesconto : double
  - valorDevido : double
  - valorPago : double
  + prepararSaida(saida : LocalDateTime)
  + registrarCobranca(custo, id, desconto, pago)
  + getHorasCobraveis() : long
  + getQuantidadeViradasDeDia() : long
}

interface Desconto {
  + aplicar(valorOriginal : double) : double
  + getId() : String
}
class DescontoClienteFrequente
Desconto <|.. DescontoClienteFrequente

class TabelaTarifas {
  - valorHora : double
  - valorDiaria : double
  - valorIngresso : double
  - multaAtraso : double
}

class Estacionamento {
  - clientesCadastrados : Map<String, Cliente>
  - veiculosCadastrados : Map<String, Veiculo>
  - placasBloqueadas : Set<String>
  - registrosAtivos : Map<String, RegistroEstacionamento>
  - historico : List<RegistroEstacionamento>
  + cadastrarCliente(cliente : Cliente)
  + cadastrarPlaca(id, placa) : boolean
  + removerPlaca(id, placa) : boolean
  + autorizarEntrada(placa, momento) : boolean
  + processarSaida(placa, momento, pagamento) : double
  + relatorioArrecadacao(inicio, fim, categorias) : double
  + relatorioSituacaoCliente(id) : String
  + relatorioRegistrosCliente(id, inicio, fim) : List
  + relatorioRegistrosAvulso(placa, inicio, fim) : List
  + relatorioImpedidos() : Set
  + relatorioTop10Frequentes(ano) : Map
}

class CSVManager {
  - diretorio : Path
  + carregarTudo(tarifas) : Estacionamento
  + salvarTudo(estacionamento)
  + instalarSalvamentoAutomatico(estacionamento) : Thread
}

class InterfaceUsuario <<Vaadin Route>>
class Aplicacao <<Spring Boot>>

Cliente "1" o-- "0..*" Veiculo
Estacionamento *-- Cliente
Estacionamento *-- Veiculo
Estacionamento *-- RegistroEstacionamento
Estacionamento --> TabelaTarifas
Estacionamento --> Desconto
RegistroEstacionamento --> TipoCliente
CSVManager --> Estacionamento
InterfaceUsuario --> Estacionamento
Aplicacao --> CSVManager
Aplicacao --> Estacionamento
@enduml
