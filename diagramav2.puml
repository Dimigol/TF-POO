@startuml DiagramaClassesEstacionamentoCorrigido

skinparam classAttributeIconSize 0
hide circle
title Sistema de Controle de Estacionamento - Diagrama de Classes Corrigido

' ==================================================
' ENUMS
' ==================================================

enum TipoCliente {
  AVULSO
  PROFESSOR
  ESTUDANTE
  EMPRESA
}

enum MotivoBloqueio {
  RECUSA_PAGAMENTO
  SALDO_NEGATIVO
  INADIMPLENCIA_EMPRESA
}

enum StatusBoleto {
  ABERTO
  PAGO
  VENCIDO
}

' ==================================================
' CLIENTES
' ==================================================

abstract class ClienteCadastrado {
  - id : String
  - nome : String
  - placas : Set<String>
  + getId() : String
  + getNome() : String
  + getPlacas() : Set<String>
  + adicionarPlaca(placa:String) : boolean
  + removerPlaca(placa:String) : boolean
  + possuiPlaca(placa:String) : boolean
  + {abstract} limitePlacas() : int
  + {abstract} podeEntrar(placa:String, placasEstacionadas:Set<String>) : boolean
  + {abstract} getTipo() : TipoCliente
}

class Professor {
  + limitePlacas() : int
  + podeEntrar(placa:String, placasEstacionadas:Set<String>) : boolean
  + temVeiculoEstacionado(placasEstacionadas:Set<String>) : boolean
  + getTipo() : TipoCliente
}

class Estudante {
  - saldo : double
  + creditar(valor:double) : void
  + debitar(valor:double) : void
  + getSaldo() : double
  + temSaldoNegativo() : boolean
  + limitePlacas() : int
  + podeEntrar(placa:String, placasEstacionadas:Set<String>) : boolean
  + getTipo() : TipoCliente
}

class Empresa {
  - debitoAcumulado : double
  - inadimplente : boolean
  + adicionarDebito(valor:double) : void
  + registrarPagamento(valor:double) : void
  + emitirBoleto(dataVencimento:LocalDate) : Boleto
  + marcarInadimplente() : void
  + regularizarPendencia() : void
  + estaInadimplente() : boolean
  + limitePlacas() : int
  + podeEntrar(placa:String, placasEstacionadas:Set<String>) : boolean
  + getTipo() : TipoCliente
}

class ClienteAvulso {
  - placa : String
  + getPlaca() : String
}

ClienteCadastrado <|-- Professor
ClienteCadastrado <|-- Estudante
ClienteCadastrado <|-- Empresa

note right of ClienteAvulso
  Cliente avulso nao possui CPF/CNPJ.
  Ele e identificado somente pela placa.
end note

note right of ClienteCadastrado
  Representa apenas clientes pre-cadastrados.
  Veiculos pre-cadastrados nunca devem
  usar a modalidade avulsa.
end note

note right of Professor
  Maximo de 2 placas.
  Entrada gratuita.
  Apenas 1 veiculo estacionado por vez;
  se tentar usar o segundo simultaneamente,
  a entrada deve ser negada como cadastrado.
end note

note right of Estudante
  Maximo de 1 placa.
  Uso pre-pago.
  Se o saldo ficar negativo na saida,
  novas entradas devem ser bloqueadas.
end note

note right of Empresa
  Placas ilimitadas.
  Todos os veiculos podem estacionar juntos.
  Cobra diaria e multa se passar da meia-noite.
  Inadimplencia bloqueia todos os veiculos.
end note

' ==================================================
' VEICULOS
' ==================================================

class Veiculo {
  - placa : String
  + getPlaca() : String
}

ClienteCadastrado "1" o-- "0..*" Veiculo : cadastra >

' ==================================================
' REGISTRO E PAGAMENTO
' ==================================================

class RegistroEstacionamento {
  - id : String
  - placa : String
  - tipoCliente : TipoCliente
  - entrada : LocalDateTime
  - saida : LocalDateTime
  + registrarSaida(saida:LocalDateTime, pagamento:Pagamento) : void
  + calcularDuracao() : Duration
  + estaAtivo() : boolean
}

class Pagamento {
  - custoOriginal : double
  - idDesconto : String
  - valorDesconto : double
  - valorDevido : double
  - valorPago : double
  - dataPagamento : LocalDateTime
  + foiPagoIntegralmente() : boolean
}

RegistroEstacionamento "1" *-- "0..1" Pagamento : pagamento >
RegistroEstacionamento "0..*" --> "0..1" Veiculo : referencia >

' ==================================================
' COBRANCA
' ==================================================

interface PoliticaCobranca {
  + calcular(registro:RegistroEstacionamento, tarifas:TabelaTarifas) : double
}

class CobrancaProfessor
class CobrancaEstudante
class CobrancaEmpresa
class CobrancaAvulso

PoliticaCobranca <|.. CobrancaProfessor
PoliticaCobranca <|.. CobrancaEstudante
PoliticaCobranca <|.. CobrancaEmpresa
PoliticaCobranca <|.. CobrancaAvulso

note right of CobrancaAvulso
  Cobra por hora ate 6 horas.
  Acima de 6 horas, cobra diaria.
  Se ultrapassar meia-noite,
  uma nova diaria deve ser cobrada.
end note

note right of CobrancaEstudante
  Valor fixo por ingresso.
  Se sair apos a meia-noite,
  cobra novo ingresso.
end note

note right of CobrancaEmpresa
  Cobra diaria.
  Se permanecer apos meia-noite,
  aplica multa adicional por dia.
end note

note right of CobrancaProfessor
  Custo zero.
  Registros ficam para controle e seguro.
end note

' ==================================================
' DESCONTOS
' ==================================================

interface Desconto {
  + getId() : String
  + ehAplicavel(registro:RegistroEstacionamento, historico:List<RegistroEstacionamento>) : boolean
  + calcularDesconto(valorOriginal:double) : double
}

class DescontoClienteFrequente

class VerificadorFrequencia {
  + usouNosUltimosTresDias(placa:String, dataReferencia:LocalDate, historico:List<RegistroEstacionamento>) : boolean
}

Desconto <|.. DescontoClienteFrequente
DescontoClienteFrequente --> VerificadorFrequencia : usa >

note right of DescontoClienteFrequente
  Aplicado somente a clientes avulsos.
  Se a placa usou o estacionamento
  pelo menos uma vez nos ultimos 3 dias,
  recebe 10% de desconto.
end note

' ==================================================
' BOLETOS E BLOQUEIOS
' ==================================================

class Boleto {
  - numero : String
  - valor : double
  - emissao : LocalDate
  - vencimento : LocalDate
  - status : StatusBoleto
  + registrarPagamento(data:LocalDate) : void
  + estaVencido(dataAtual:LocalDate) : boolean
}

Empresa "1" o-- "0..*" Boleto : emite >

class Bloqueio {
  - placa : String
  - motivo : MotivoBloqueio
  - data : LocalDate
  - ativo : boolean
  + desativar() : void
}

' ==================================================
' TARIFAS
' ==================================================

class TabelaTarifas {
  - valorHoraAvulso : double
  - valorDiariaAvulso : double
  - valorIngressoEstudante : double
  - valorDiariaEmpresa : double
  - multaEmpresaPorDia : double
  + carregarDeArquivo(caminho:String) : void
  + getValorHoraAvulso() : double
  + getValorDiariaAvulso() : double
  + getValorIngressoEstudante() : double
  + getValorDiariaEmpresa() : double
  + getMultaEmpresaPorDia() : double
}

' ==================================================
' PERSISTENCIA CSV
' ==================================================

interface CSVRepository {
  + carregar(caminho:String) : void
  + salvar(caminho:String) : void
}

class ClienteCSVRepository {
  + carregarClientes(caminho:String) : Map<String, ClienteCadastrado>
  + salvarClientes(caminho:String, clientes:Map<String, ClienteCadastrado>) : void
}

class VeiculoCSVRepository {
  + carregarVeiculos(caminho:String) : Map<String, Veiculo>
  + salvarVeiculos(caminho:String, veiculos:Map<String, Veiculo>) : void
}

class RegistroCSVRepository {
  + carregarRegistros(caminho:String) : List<RegistroEstacionamento>
  + salvarRegistros(caminho:String, registros:List<RegistroEstacionamento>) : void
}

class BloqueioCSVRepository {
  + carregarBloqueios(caminho:String) : Map<String, Bloqueio>
  + salvarBloqueios(caminho:String, bloqueios:Map<String, Bloqueio>) : void
}

CSVRepository <|.. ClienteCSVRepository
CSVRepository <|.. VeiculoCSVRepository
CSVRepository <|.. RegistroCSVRepository
CSVRepository <|.. BloqueioCSVRepository

' ==================================================
' RELATORIOS
' ==================================================

class GeradorRelatorios {
  + arrecadacao(inicio:LocalDate, fim:LocalDate) : double
  + arrecadacaoPorCategoria(inicio:LocalDate, fim:LocalDate, tipos:Set<TipoCliente>) : double
  + situacaoCliente(idCliente:String) : String
  + registrosClienteCadastrado(idCliente:String, inicio:LocalDate, fim:LocalDate) : List<RegistroEstacionamento>
  + registrosClienteAvulso(placa:String, inicio:LocalDate, fim:LocalDate) : List<RegistroEstacionamento>
  + clientesImpedidos() : List<Bloqueio>
  + top10Frequentes(ano:int) : List<String>
}

' ==================================================
' FACHADA PRINCIPAL DO SISTEMA
' ==================================================

class Estacionamento {
  - capacidadeTotal : int = 9000
  - clientes : Map<String, ClienteCadastrado>
  - veiculosCadastrados : Map<String, Veiculo>
  - proprietariosPorPlaca : Map<String, ClienteCadastrado>
  - registrosAtivos : Map<String, RegistroEstacionamento>
  - historico : List<RegistroEstacionamento>
  - placasBloqueadas : Set<String>
  - bloqueios : Map<String, Bloqueio>
  - politicasCobranca : Map<TipoCliente, PoliticaCobranca>
  - descontos : List<Desconto>
  - tarifas : TabelaTarifas
  + vagasDisponiveis() : int
  + cadastrarCliente(cliente:ClienteCadastrado) : void
  + cadastrarPlaca(idCliente:String, placa:String) : boolean
  + removerPlaca(idCliente:String, placa:String) : boolean
  + autorizarEntrada(placa:String, momento:LocalDateTime) : boolean
  + processarSaida(placa:String, momento:LocalDateTime, valorPago:double) : double
  + registrarRecusaPagamento(placa:String) : void
  + bloquearPlaca(placa:String, motivo:MotivoBloqueio) : void
  + desbloquearPlaca(placa:String) : void
  + carregarDados() : void
  + salvarDados() : void
}

Estacionamento "1" *-- "0..*" RegistroEstacionamento : historico >
Estacionamento "1" *-- "0..*" Bloqueio : bloqueios >
Estacionamento "1" o-- "0..*" ClienteCadastrado : clientes >
Estacionamento "1" o-- "0..*" Veiculo : veiculos >
Estacionamento "1" --> "1" TabelaTarifas : usa >
Estacionamento "1" --> "1..*" PoliticaCobranca : usa >
Estacionamento "1" --> "0..*" Desconto : aplica >
Estacionamento "1" --> "1" ClienteCSVRepository : persiste >
Estacionamento "1" --> "1" VeiculoCSVRepository : persiste >
Estacionamento "1" --> "1" RegistroCSVRepository : persiste >
Estacionamento "1" --> "1" BloqueioCSVRepository : persiste >
GeradorRelatorios "1" --> "1" Estacionamento : consulta >

note bottom of Estacionamento
  Os Map agilizam busca por cliente, placa e registros ativos.
  O Set de placas bloqueadas permite verificar rapidamente
  se uma placa esta impedida de entrar.
  O historico guarda os registros finalizados para relatorios.
end note

' ==================================================
' INTERFACE VAADIN
' ==================================================

class InterfaceUsuarioVaadin <<Vaadin>> {
  - estacionamento : Estacionamento
  + telaCadastroCliente() : void
  + telaCadastroPlacas() : void
  + telaEntradaSaida() : void
  + telaRelatorios() : void
  + salvarAoEncerrar() : void
}

InterfaceUsuarioVaadin "1" --> "1" Estacionamento : usa >

@enduml